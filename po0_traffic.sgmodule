#!name=po0 流量监控
#!desc=显示 po0 VPS 剩余流量
#!arguments=email=&password=

[Panel]
po0Traffic = title="po0 流量监控",content="点击刷新查询流量",icon=arrow.up.arrow.down.circle.fill,icon-color=#6ECB63,script-name=po0TrafficScript,update-interval=3600

[Script]
po0TrafficScript = type=generic,timeout=30,script-path=https://raw.githubusercontent.com/kukubob/po0-traffic-surge/master/po0_traffic.js,script-update-interval=0,argument=email=%email%&password=%password%

